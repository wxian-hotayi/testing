# Staging environment template — copy to .env.staging and fill with REAL staging
# values (a Supabase project + Stripe account SEPARATE from production).
# .env.staging is gitignored; never commit real secrets.
#
# Supabase (staging project — Auth + Storage + RLS enabled):
NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (TEST MODE ONLY for staging; Connect enabled; separate webhook secret):
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App:
NEXT_PUBLIC_SITE_URL=https://staging.<your-domain>

# Cron / email (optional):
CRON_SECRET=
RESEND_API_KEY=
