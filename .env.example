# =============================================================================
# Vitalis Commerce — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Variables prefixed NEXT_PUBLIC_ are exposed to the
# browser; everything else is server-only.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the site (no trailing slash). Used for canonical URLs,
# sitemaps, OG tags, Stripe redirects, and email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Project URL + anon key are safe for the browser (RLS protects data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Service-role key bypasses RLS — server-only, NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From the Stripe CLI (`stripe listen`) or dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend (transactional + marketing email) --------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM="Vitalis <hello@yourdomain.com>"
EMAIL_REPLY_TO=support@yourdomain.com

# --- Analytics ---------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# --- Cron / automation -------------------------------------------------------
# Shared secret used to authorize scheduled jobs (abandoned cart, emails).
CRON_SECRET=generate_a_long_random_string
